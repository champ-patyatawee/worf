<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for creating pseudo-terminals (portable-pty) -->
    <key>com.apple.security.device.pty</key>
    <true/>

    <!-- Required for spawning child processes with TTY access -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required for dynamic library loading in PTY context -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Allow JIT compilation for PTY child processes (opencode, neovim, etc.) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow debug attachment to child processes for signal forwarding -->
    <key>com.apple.security.get-task-allow</key>
    <true/>
</dict>
</plist>
