# Database
DATABASE_URL=postgresql://workspace:workspace_dev@localhost:5432/workspace

# Test Database (for e2e tests)
TEST_DATABASE_URL=postgresql://workspace:workspace_dev@localhost:5432/workspace_test

# JWT Authentication
