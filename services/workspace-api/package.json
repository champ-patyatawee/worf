{
  "name": "workspace-api",
  "version": "1.0.0",
  "description": "workspace backend API server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch ./src/index.ts",
    "worker": "tsx watch ./src/workers/embeddingWorker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest.e2e.config.cjs --runInBand"
  },
  "dependencies": {
    "@esbuild/darwin-x64": "^0.28.0",
    "@kubernetes/client-node": "^0.20.0",
    "@prisma/client": "^5.10.0",
    "@types/uuid": "^10.0.0",
    "@xenova/transformers": "^2.17.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.0",
    "node-pty": "^1.1.0",
    "pg-boss": "^12.15.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.4",
    "spdy": "^4.0.2",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/spdy": "^3.4.9",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
